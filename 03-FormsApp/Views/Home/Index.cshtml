@model ProductViewModel

@{
    ViewData["Title"] = "Home Page";
}

<div class="card card-body product-filter my-3">
    <form asp-action="Index" method="get">
        <div class="container">
            <div class="row">
                <div class="col-md-11">
                    <select name="category"
                            class="form-select"
                            asp-items="@(new SelectList(Model.Categories, "CategoryId", "Name", Model.SelectedCategory))">
                        <option value="0">Hepsi</option>
                    </select>
                </div>

                <div class="col-md-1">
                    <button type="submit" class="btn btn-primary">Filtrele</button>
                </div>
            </div>
        </div>
    </form>
</div>

<form asp-action="EditProducts" method="post">
<table class="table table-striped align-middle product-table">
    <thead>
        <tr>
            <th style="width:100px">@Html.DisplayNameFor(m => m.Products[0].ProductId)</th>
            <th style="width:100px">@Html.DisplayNameFor(m => m.Products[0].Image)</th>
            <th style="width:100px">@Html.DisplayNameFor(m => m.Products[0].Name)</th>
            <th style="width:100px">@Html.DisplayNameFor(m => m.Products[0].Price)</th>
            <th style="width:130px"></th>
            <td></td>
        </tr>
    </thead>

    <tbody>
        @for (var i = 0; i < Model.Products.Count; i++)
        {
            <tr>
                <td>@Model.Products[i].ProductId
                    <input type="hidden" asp-for="@Model.Products[i].ProductId" />
                </td>

                <td>
                    <img src="~/img/@Model.Products[i].Image"
                         class="product-img"
                         alt="@Model.Products[i].Name" />
                </td>

                <td>@Model.Products[i].Name</td>
                <td>@Model.Products[i].Price</td>

                <td>
                    <input type="checkbox"
                           asp-for="@Model.Products[i].IsActive" />
                </td>

                <td>
                    <a class="btn btn-sm btn-primary"
                       asp-controller="Home"
                       asp-action="Edit"
                       asp-route-id="@Model.Products[i].ProductId">
                        Edit
                    </a>

                    <a class="btn btn-sm btn-danger"
                       asp-controller="Home"
                       asp-action="Delete"
                       asp-route-id="@Model.Products[i].ProductId">
                        Delete
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>
<button type="submit" class="btn btn-primary">Kaydet</button>
</form>
