@model Course
<div class="card course-card mb-3" id=kurs_@Model.Id>
    <div class="row g-0">
        <div class="col-md-4">
            <img src="~/img/@Model.Image" class="img-fluid rounded-start course-list-img" alt="@Model.Title" />
        </div>
        <div class="col-md-8 card-body">
            
                <a asp-controller="Course" asp-action="Details" asp-route-id="@Model.Id">
                    <h5 class="card-title">
                        @Model.Title
                    </h5>
                </a>
              
                <p class="card-text text-secondary">@Model.Description</p>
            <div>
                @if (Model.Tags != null)
                {
                    @foreach (var tag in Model.Tags)
                    {
                        <span class="badge bg-primary">@tag</span>
                    }
                }
               
            </div>
            
        </div>
    </div>
</div>
