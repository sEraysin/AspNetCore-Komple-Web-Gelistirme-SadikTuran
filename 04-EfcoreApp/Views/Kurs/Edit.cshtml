@model Kurs

<h2>Kurs Güncelle</h2>
<hr />
<div asp-validation-summary="All" class="text-danger"></div>
<div class="row">
    <div class="col-8">
        <form asp-controller="Kurs" asp-action="Edit" method="post">
            <input type="hidden" asp-for="KursId" />
            <div class="mb-3">
                <label asp-for="Baslik" class="form-label">Baslik</label>
                <input asp-for="Baslik" class="form-control" />
            </div>
            <div class="mb-3">
                <label asp-for="OgretmenId" class="form-label">Ögretmen</label>
                <select asp-for="OgretmenId" asp-items="ViewBag.Ogretmenler" class="form-select">
                    <option value="">Seciniz</option>
                </select>
            </div>
    
            <button type="submit" class="btn btn-secondary">Kaydet</button>
        </form>
    </div>
    <div class="col-4">
        <h4>Ögrenciler</h4>
        <hr />
        @foreach(var item in Model.KursKayitlari)
        {
            <li>@item.Ogrenci.AdSoyad</li>
        }
    </div>
</div>
