@model List<Course>

@section _Header {
    @await Html.PartialAsync("_Header")
}

<div class="row g-4">
   
    @foreach (var kurs in Model)
    {
        @if(kurs.isActive && kurs.isHome)
        {
            
       
        <div class="col-sm-6 col-lg-4 col-xl-3">
            <div class="card course-card h-100">
                <img src="~/img/@kurs.Image" class="card-img-top course-card-img" alt="@kurs.Title" />

                <div class="card-body d-flex flex-column">
                    <h5 class="card-title">
                        @kurs.Title
                    </h5>

                    <p class="card-text text-secondary">
                        @kurs.Description
                    </p>

                    <a class="btn btn-primary mt-auto"
                       asp-controller="Course"
                       asp-action="Details"
                       asp-route-id="@kurs.Id">
                        Detay
                    </a>
                </div>
            </div>
        </div>
        }
    }
</div>
