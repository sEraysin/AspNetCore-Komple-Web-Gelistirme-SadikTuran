@page "/personel/{id:int}"
@model razorpagesExample.Pages.Employees.DetailsModel
@{
    ViewData["Title"] = "Details";
}

<h1 class="mb-4">Details Page</h1>

<div class="row">
    <div class="col-md-6 col-lg-4">

        @if (Model.Employee != null)
        {
            <div class="card h-100Shadow">
                <img src="/img/@Model.Employee.Photo" class="card-img-top" alt="@Model.Employee.Name" style="height: 300px; object-fit: cover;" />

                <div class="card-body d-flex flex-column justify-content-between">
                    <div>
                        <h5 class="card-title">@Model.Employee.Name</h5>
                        <p class="card-text text-muted">@Model.Employee.Department</p>
                        <p class="card-text text-muted">@Model.Employee.Email</p>
                    </div>

                    <a asp-page="Index" class="btn btn-secondary mt-3">Geri Dön</a>
                </div>
            </div>
        }
        else
        {
            <div class="alert alert-danger">Personel bulunamadı!</div>
            <a asp-page="Index" class="btn btn-secondary">Listeye Dön</a>
        }
    </div>
</div>