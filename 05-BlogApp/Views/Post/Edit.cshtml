
@model PostCreateViweModel

<form asp-action="Edit" method="post">
<div class="row justify-content-center mt-4">
    <div class="col-md-8 col-9">
        <div class="card shadow-sm p-4 border-0 border-top border-primary border-4">
            <h1 class="h3 mb-4 text-primary">Post Edit</h1>

           
                @Html.AntiForgeryToken()

                <div asp-validation-summary="All" class="text-danger mb-3"></div>
                <input type="hidden" asp-for="PostId" />
                <div class="mb-3">
                    <label asp-for="Title" class="form-label font-weight-bold"></label>
                    <input asp-for="Title" class="form-control" placeholder="Başlık giriniz..." />
                    <span asp-validation-for="Title" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Description" class="form-label font-weight-bold"></label>
                    <input asp-for="Description" class="form-control" placeholder="Kısa açıklama..." />
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Url" class="form-label font-weight-bold"></label>
                    <input asp-for="Url" class="form-control" placeholder="post-url-adresi" />
                    <span asp-validation-for="Url" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Content" class="form-label font-weight-bold"></label>
                    <textarea asp-for="Content" class="form-control" rows="5" placeholder="İçerik yazısını buraya giriniz..."></textarea>
                    <span asp-validation-for="Content" class="text-danger"></span>
                </div>

                <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                    @if (User.FindFirstValue(ClaimTypes.Role) == "admin")
                    {
                        <div class="form-check mb-3">
                            <input type="checkbox" asp-for="IsActive" class="form-check-input" />

                            <label asp-for="IsActive" class="form-check-label"></label>
                        </div>
                    }

                    <button type="submit" class="btn btn-primary px-4">Kaydet</button>
                </div>
           
        </div>
    </div>
    <div class="col-3">
        <div class="bg-white p-4">

            @foreach (var tag in ViewBag.Tags)
            {
                <div class="form-check">
                    <input class="form-check-input"
                    name="tagIds"
                    type="checkbox" 
                    value="@tag.TagId" 
                    id="tag_@tag.TagId"
                    @(Model.Tags.Any(i => i.TagId == tag.TagId) ? "checked" : "")>
                    <label class="form-check-label" for="tag_@tag.TagId">
                        @tag.Text
                    </label>
                </div>
            }

        </div>
    </div>
</div>
</form>

@section Scripts {
    <script>
        tinymce.init({
            selector: '#Content',
            setup: function (editor) {
                editor.on('change', function () {
                    tinymce.triggerSave();
                });
            }
        });
    </script>
}